# Secure Claude Baseline — example env file.
# Copy to `.env` locally; `.env` is gitignored and must NEVER be committed.
# In production, source these from your secrets manager (AWS Secrets Manager, Vault, etc.).

# ---- Claude Code MCP servers ----

# GitHub MCP — use a fine-grained PAT scoped to the repos the agent legitimately needs,
# with read-only contents + issues permissions. No write unless you've threat-modelled it.
GH_PAT_READONLY=github_pat_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Filesystem MCP — scope to the project root, never `/` or `$HOME`.
PROJECT_ROOT=/absolute/path/to/your/project

# ---- Notification hook (optional) ----

# Slack webhook for the Notification hook. If unset, the hook is a no-op.
SLACK_WEBHOOK_URL=

# ---- Audit log (.claude/hooks/audit-log.sh) ----
# The hook always writes locally first, then optionally forwards to remote
# sinks. Local failures never break the session; remote failures are silent.

# Where the local sink stores records. Default: .claude/audit
CLAUDE_AUDIT_DIR=.claude/audit

# Local sink selection. auto = sqlite if sqlite3 is on PATH, else jsonl.
# Other values: sqlite, jsonl, both, none.
CLAUDE_AUDIT_SINK=auto

# Max bytes of tool_input preview to retain. Larger = richer records but
# more disk / network. Default: 2048.
CLAUDE_AUDIT_MAX_PREVIEW=2048

# Set to 0 to skip secret-shape redaction (NOT recommended — the redactor
# strips AWS/GitHub/Slack/OpenAI/private-key shapes and JSON credential
# keys before records leave the box). Default: 1.
CLAUDE_AUDIT_REDACT=1

# Remote sink: Sumo Logic HTTP Source. Grab the URL from the collector UI;
# the token is embedded in the URL, no separate auth header needed.
# Unset by default (no remote forwarding).
CLAUDE_AUDIT_SUMO_URL=

# Remote sink: generic HTTPS endpoint — works for Splunk HEC, Datadog logs,
# Elastic/Logstash HTTP input, or any webhook. Unset by default.
CLAUDE_AUDIT_HTTP_URL=

# Optional Authorization header value for CLAUDE_AUDIT_HTTP_URL.
# Examples:
#   "Splunk <HEC-token>"          (Splunk HEC)
#   "Bearer <token>"              (generic bearer)
#   "DD-API-KEY <key>"            (Datadog)
CLAUDE_AUDIT_HTTP_AUTH=

# ---- Break-glass override (block-destructive.sh) ----
# Set to a reason string (ticket ID, approver name) to allow a normally-
# blocked destructive command for ONE session. Every bypass is written to
# .claude/audit/breakglass.log and stamped on every audit record via
# `breakglass_reason`. Leave unset for normal operation.
CLAUDE_BREAKGLASS=

# ---- Prompt-injection scanner (prompt-injection-scan.sh) ----
# warn  : stderr warning, read proceeds (default — minimises false-positive friction)
# block : exit 2 on detection, refuses the read
# off   : disable the check entirely
CLAUDE_PROMPT_INJECTION=warn
