# Secure Claude Baseline — example env file.
# Copy to `.env` locally; `.env` is gitignored and must NEVER be committed.
# In production, source these from your secrets manager (AWS Secrets Manager, Vault, etc.).

# ---- Claude Code MCP servers ----

# GitHub MCP — use a fine-grained PAT scoped to the repos the agent legitimately needs,
# with read-only contents + issues permissions. No write unless you've threat-modelled it.
GH_PAT_READONLY=github_pat_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Filesystem MCP — scope to the project root, never `/` or `$HOME`.
PROJECT_ROOT=/absolute/path/to/your/project

# ---- Notification hook (optional) ----

# Slack webhook for the Notification hook. If unset, the hook is a no-op.
SLACK_WEBHOOK_URL=

# ---- Audit log location (optional) ----
# Defaults to .claude/audit if unset.
CLAUDE_AUDIT_DIR=.claude/audit
